{
  "name": "discord-basic-bot",
  "version": "1.0.0",
  "description": "A basic Discord bot with modular handlers",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "send-rules": "node src/scripts/sendRules.js",
    "send-obtainium": "node src/scripts/sendObtainium.js",
    "lint": "node node_modules/eslint/bin/eslint.js src",
    "lint:fix": "node node_modules/eslint/bin/eslint.js src --fix",
    "format": "node node_modules/prettier/bin/prettier.cjs --write src",
    "format:check": "node node_modules/prettier/bin/prettier.cjs --check src",
    "fetch-repos": "node src/scripts/fetchRepos.js"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "eslint": "^10.4.1",
    "prettier": "^3.8.3"
  }
}
